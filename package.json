{
  "name": "jixiang-001",
  "version": "1.0.0",
  "description": "集享公社 · 轻奢金融风商城+增值理财（独立部署版）",
  "scripts": {
    "postinstall": "node scripts/optimize-assets.mjs",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "dev:h5": "uni -p h5",
    "build:h5": "uni build -p h5 && node scripts/fix-glob.js",
    "preview:mall": "npm run build:h5 && node scripts/preview-mall.mjs",
    "preview:h5": "npm run preview:mall",
    "verify:h5": "node scripts/verify-h5-build.mjs",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:mp-weixin": "uni build -p mp-weixin",
    "lint": "eslint src --ext .vue,.ts,.tsx --fix",
    "lint:check": "eslint src --ext .vue,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,scss,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-3060520221121001",
    "@dcloudio/uni-app-plus": "3.0.0-3060520221121001",
    "@dcloudio/uni-components": "3.0.0-3060520221121001",
    "@dcloudio/uni-h5": "3.0.0-3060520221121001",
    "@dcloudio/uni-mp-weixin": "3.0.0-3060520221121001",
    "vue": "3.2.39"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-3060520221121001",
    "@dcloudio/uni-cli-shared": "3.0.0-3060520221121001",
    "@dcloudio/vite-plugin-uni": "3.0.0-3060520221121001",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.24.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.2.0",
    "sass": "1.77.0",
    "typescript": "^5.4.5",
    "vite": "5.2.8"
  }
}
